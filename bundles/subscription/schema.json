{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "apiVersion": {
      "const": "terramate.io/cli/v1"
    },
    "kind": {
      "const": "BundleInstance"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "uuid": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "uuid"
      ]
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string"
        },
        "inputs": {
          "$ref": "#/definitions/inputs"
        }
      },
      "required": [
        "source",
        "inputs"
      ]
    },
    "environments": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "inputs": {
            "$ref": "#/definitions/inputs"
          }
        }
      }
    }
  },
  "definitions": {
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": {
          "type": "object",
          "title": "Network configuration",
          "markdownDescription": "Network configuration for the subscription",
          "default": {},
          "properties": {
            "cidr_range": {
              "type": "string",
              "title": "Network: CIDR Range",
              "markdownDescription": "Optional: Enter a CIDR range if this project should get a VNet",
              "default": ""
            },
            "internet_allowed_fqdns": {
              "type": "array",
              "title": "Network: Allowed Internet FQDNs",
              "markdownDescription": "Enter the FQDNs which this workload is allowed to access",
              "items": {
                "type": "string"
              },
              "default": []
            }
          }
        },
        "state_import": {
          "type": "array",
          "title": "",
          "markdownDescription": "Import existing infrastructure using Terraform import blocks.",
          "items": {
            "type": "object",
            "properties": {
              "to": {
                "type": "string",
                "title": "",
                "markdownDescription": "The instance address to import the resource into. It must match the address of an existing `resource` block."
              },
              "id": {
                "type": "string",
                "title": "",
                "markdownDescription": "The cloud provider's ID for the resource to import."
              }
            }
          },
          "default": []
        },
        "state_moved": {
          "type": "array",
          "title": "",
          "markdownDescription": "Move resources in Terraform state from one address to another.",
          "items": {
            "type": "object",
            "properties": {
              "from": {
                "type": "string",
                "title": "",
                "markdownDescription": "The resources's previous address."
              },
              "to": {
                "type": "string",
                "title": "",
                "markdownDescription": "The new address to relocate the resource to."
              }
            }
          },
          "default": []
        },
        "tenant": {
          "type": "string",
          "title": "Tenant",
          "markdownDescription": "Choose the tenant to which this project belongs"
        },
        "project": {
          "type": "string",
          "title": "Project name",
          "markdownDescription": "Choose a project name (lowercase)"
        },
        "budget_amount": {
          "type": "number",
          "title": "Monthly budget",
          "markdownDescription": "Enter the monthly budget in EUR",
          "default": 0
        },
        "resource_providers": {
          "type": "array",
          "title": "Resource Providers",
          "markdownDescription": "Resource providers for the subscription",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "iam_admin_users": {
          "type": "array",
          "title": "IAM: Admin Users",
          "markdownDescription": "Please enter a list of admins",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "iam_readonly_users": {
          "type": "array",
          "title": "IAM: ReadOnly Users",
          "markdownDescription": "Please enter a list of readonly users",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
